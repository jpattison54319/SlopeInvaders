# Classroom cloud (optional). Leave unset to run fully offline on localStorage.
# Fill these in after creating a Supabase project + running the migrations in
# supabase/migrations/. See DEPLOYMENT.md.
#
# This is a Vite app, so browser env vars must be prefixed VITE_. The key may be
# the legacy anon JWT OR the new publishable key (sb_publishable_...) set as
# VITE_SUPABASE_ANON_KEY (or VITE_SUPABASE_PUBLISHABLE_KEY); both are safe to ship.
VITE_SUPABASE_URL=
# Supabase Project Settings → API → "Publishable key" (sb_publishable_…).
# Safe to ship in the frontend. (The legacy VITE_SUPABASE_ANON_KEY name still
# works as a fallback.)
VITE_SUPABASE_PUBLISHABLE_KEY=
