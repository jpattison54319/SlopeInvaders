# Classroom cloud (optional). Leave unset to run fully offline on localStorage.
# Fill these in after creating a Supabase project + running
# supabase/migrations/0001_classroom.sql. See DEPLOYMENT.md.
VITE_SUPABASE_URL=
# Supabase Project Settings → API → "Publishable key" (sb_publishable_…).
# Safe to ship in the frontend. (The legacy VITE_SUPABASE_ANON_KEY name still
# works as a fallback.)
VITE_SUPABASE_PUBLISHABLE_KEY=
